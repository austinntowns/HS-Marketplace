DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:pass@host/db?sslmode=require
AUTH_SECRET=your-secret-at-least-32-characters-long
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret
RESEND_API_KEY=re_your_resend_api_key
INITIAL_ADMIN_EMAIL=admin@hellosugar.salon
GOOGLE_WORKSPACE_DOMAIN=hellosugar.salon

# Vercel Blob (photo uploads)
# Get from: Vercel Dashboard > Storage > Create Database > Blob > Connect
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# MapTiler (map tiles and location autocomplete)
# Get from: MapTiler Cloud (https://cloud.maptiler.com) -> Account -> API Keys
# Restrict key to production domain in MapTiler Cloud -> API Keys -> Edit -> Allowed URLs
NEXT_PUBLIC_MAPTILER_API_KEY=your_maptiler_api_key

# Hello Sugar Internal API (Phase 4)
HS_INTERNAL_API_URL=https://api.hellosugar.salon/v1
HS_INTERNAL_API_TOKEN=your-internal-api-token
